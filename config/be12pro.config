CONFIG_first_card_EEPROM_def_bin_path="/lib/firmware/MT7992_EEPROM.bin"
CONFIG_first_card_main_ifname="ra0;rai0"
CONFIG_first_card_ext_ifname="ra;rai"
CONFIG_first_card_wds_ifname="wds;wdsi"
CONFIG_first_card_apcli_ifname="apcli;apclii"
CONFIG_first_card_mesh_ifname="mesh;meshi"
CONFIG_first_card_nvram_zone="dev00;dev01"
CONFIG_first_card_single_sku_path="/rom/etc/wireless/mediatek/mt7992-sku.dat"
CONFIG_first_card_bf_sku_path="/rom/etc/wireless/mediatek/mt7992-sku-bf.dat"
# CONFIG_second_card is not set
# CONFIG_third_card is not set

