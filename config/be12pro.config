# Minimal seed for Tenda BE12 Pro CI
# Base: chasey-dev/immortalwrt-mt798x-rebase @ 25.12-dev-wifi7
#        defconfig/low-mem-512m/mt7987-mt7992-be7200.config
# Adapted: single-device tenda_be12-pro (dropped MULTI_PROFILE / routerich_be7200)
# Date: 2026-07-18

CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_tenda_be12-pro=y

#######################################################################
