CONFIG_MTK_WIFI7_FW_LOG_TYPE="string_log"
CONFIG_first_card=y
CONFIG_first_card_name="MT7992"
CONFIG_first_card_profile_path="/etc/wireless/mediatek/mt7992.1.dat"
CONFIG_first_card_init_script="/lib/wifi/mtwifi.lua"
CONFIG_first_card_init_compatible="mtwifi"
CONFIG_first_card_EEPROM_offset="0x0"
CONFIG_first_card_EEPROM_size="0x15c000"
